---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../utils/paths";

function toRouteSlug(id: string): string {
  return id.replace(/\.(md|mdx)$/i, "");
}

const title = "逆引き（用途）";
const selectedTag = Astro.url.searchParams.get("tag") ?? "";

const [commands, batch, topics] = await Promise.all([
  getCollection("commands"),
  getCollection("batch"),
  getCollection("topics"),
]);

const filteredCommands = commands.filter((entry) => !entry.id.startsWith("_"));
const filteredBatch = batch.filter((entry) => !entry.id.startsWith("_"));
const filteredTopics = topics.filter((entry) => !entry.id.startsWith("_"));

const allEntries = [
  ...filteredCommands.map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    tags: entry.data.tags ?? [],
    url: withBase(`/commands/${toRouteSlug(entry.id)}/`),
    kind: "command",
  })),
  ...filteredBatch.map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    tags: entry.data.tags ?? [],
    url: withBase(`/batch/${toRouteSlug(entry.id)}/`),
    kind: "batch",
  })),
  ...filteredTopics.map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    tags: entry.data.tags ?? [],
    url: withBase(`/topics/${toRouteSlug(entry.id)}/`),
    kind: "topic",
  })),
];

const uniqueTags = Array.from(
  new Set(allEntries.flatMap((entry) => entry.tags).filter((tag) => tag && tag.trim()))
).sort((a, b) => a.localeCompare(b, "ja"));

const filteredEntries = selectedTag
  ? allEntries.filter((entry) => entry.tags.includes(selectedTag))
  : allEntries;
---

<BaseLayout title={title}>
  <h1>{title}</h1>
  <p>タグ（用途）からコマンド・バッチ・トピックを探せます。</p>

  <form action={withBase("/reverse/")} method="get" style="margin: 8px 0 16px;">
    <label style="display: inline-flex; align-items: center; gap: 8px;">
      タグ
      <select name="tag">
        <option value="" selected={selectedTag === ""}>すべて</option>
        {
          uniqueTags.map((tag) => (
            <option value={tag} selected={selectedTag === tag}>
              {tag}
            </option>
          ))
        }
      </select>
    </label>
    <md-filled-button style="margin-left: 8px;" type="submit">絞り込む</md-filled-button>
  </form>

  <nav style="display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 18px;">
    <a href={withBase("/reverse/")}>すべて</a>
    {uniqueTags.map((tag) => <a href={withBase(`/reverse/?tag=${encodeURIComponent(tag)}`)}>{tag}</a>)}
  </nav>

  {filteredEntries.length ? (
    <ul>
      {filteredEntries.map((entry) => (
        <li style="margin-bottom: 10px;">
          <a href={entry.url}>{entry.title}</a>
          {" - "}
          <span>{entry.summary}</span>
          {" "}
          <small style="color: #777;">[{entry.kind}]</small>
        </li>
      ))}
    </ul>
  ) : (
    <p>該当する項目がありません。</p>
  )}

  <Fragment slot="sidebar">
    <p>タグは frontmatter の `tags` から自動生成されます。</p>
  </Fragment>
</BaseLayout>

