---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";

const title = "検索";
const q = Astro.url.searchParams.get("q") ?? "";
const pagefindJs = withBase("/pagefind/pagefind.js");
const candidateJson = withBase("/search-candidates.json");
const siteBase = withBase("/");
---

<BaseLayout title={title} mainBg="#f2ecee">
  <form id="searchForm" class="searchForm" action={withBase("/search/")} method="get">
    <label class="searchField" aria-label="検索キーワード">
      <input id="searchInput" name="q" type="search" value={q} placeholder="Search" autocomplete="off" />
    </label>
    <div id="searchSuggest" class="searchSuggest" aria-live="polite"></div>
  </form>

  <p id="searchStatus"></p>
  <div id="searchResults"></div>

  <script type="module" define:vars={{ q, pagefindJs, candidateJson, siteBase }}>
    const formEl = document.getElementById("searchForm");
    const inputEl = document.getElementById("searchInput");
    const suggestEl = document.getElementById("searchSuggest");
    const statusEl = document.getElementById("searchStatus");
    const resultsEl = document.getElementById("searchResults");
    const withBasePath = (path) => `${siteBase}${String(path ?? "").replace(/^\/+/, "")}`;
    let candidates = [];
    let filtered = [];
    let activeIndex = -1;

    function scoreCandidate(candidate, query) {
      const q = query.toLowerCase();
      const title = candidate.title.toLowerCase();
      const aliases = (candidate.aliases ?? []).map((a) => a.toLowerCase());
      if (title === q) return 100;
      if (aliases.includes(q)) return 95;
      if (title.startsWith(q)) return 80;
      if (aliases.some((a) => a.startsWith(q))) return 70;
      if (title.includes(q)) return 50;
      if (aliases.some((a) => a.includes(q))) return 40;
      return 0;
    }

    function renderSuggestions() {
      if (!filtered.length) {
        suggestEl.style.display = "none";
        suggestEl.innerHTML = "";
        return;
      }
      suggestEl.style.display = "block";
      suggestEl.innerHTML = filtered
        .map(
          (item, idx) => `
            <a href="${withBasePath(item.path)}" style="display:block; padding:12px 14px; border-radius:10px; text-decoration:none; color:inherit; background:${idx === activeIndex ? "rgba(47,43,54,.10)" : "transparent"};">
              <strong style="font-size:1.7rem; line-height:1.3; color:#1f1b24;">${item.title}</strong>
              <div style="font-size:0.95rem; color:#4a4650; line-height:1.5;">${item.summary ?? ""}</div>
            </a>
          `
        )
        .join("");
    }

    async function initSuggest() {
      const res = await fetch(candidateJson);
      if (!res.ok) return;
      const json = await res.json();
      candidates = json.candidates ?? [];
    }

    function onInput() {
      const keyword = (inputEl?.value ?? "").trim();
      activeIndex = -1;
      if (!keyword) {
        filtered = [];
        renderSuggestions();
        return;
      }

      filtered = candidates
        .map((c) => ({ c, s: scoreCandidate(c, keyword) }))
        .filter((x) => x.s > 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 8)
        .map((x) => x.c);

      renderSuggestions();
    }

    async function runSearch() {
      if (!q?.trim()) {
        return;
      }

      statusEl.textContent = `「${q}」を検索中...`;
      let candidateHtml = "";

      try {
        const candidateRes = await fetch(candidateJson);
        if (candidateRes.ok) {
          const candidateData = await candidateRes.json();
          const candidateHits = (candidateData.candidates ?? [])
            .map((candidate) => ({
              candidate,
              score: scoreCandidate(candidate, q),
            }))
            .filter((x) => x.score > 0)
            .sort((a, b) => b.score - a.score)
            .slice(0, 5)
            .map((x) => x.candidate);

          if (candidateHits.length) {
            candidateHtml = `
              <section style="margin: 12px 0 20px;">
                <h2 style="font-size: 1.1rem; margin: 0 0 8px;">候補（タイトル/別名）</h2>
                ${candidateHits
                  .map(
                    (item) => `
                      <article style="padding: 10px 0; border-bottom: 1px solid #eee;">
                        <a href="${withBasePath(item.path)}" style="font-weight: 700;">${item.title}</a>
                        <p style="margin: 6px 0 0;">${item.summary ?? ""}</p>
                      </article>
                    `
                  )
                  .join("")}
              </section>
            `;
          }
        }

        await import(pagefindJs);
        const search = await window.pagefind.search(q);
        const data = await Promise.all(search.results.map((r) => r.data()));

        if (!data.length) {
          if (candidateHtml) {
            statusEl.textContent = `「${q}」の候補を表示しています。`;
            resultsEl.innerHTML = candidateHtml;
            return;
          }
          statusEl.textContent = `「${q}」の検索結果は見つかりませんでした。`;
          return;
        }

        statusEl.textContent = `「${q}」の検索結果: ${data.length}件`;
        const pagefindHtml = data
          .map(
            (item) => `
              <article style="padding: 12px 0; border-bottom: 1px solid #eee;">
                <a href="${item.url}" style="font-weight: 700;">${item.meta?.title ?? item.url}</a>
                <p style="margin: 8px 0 0;">${item.excerpt ?? ""}</p>
              </article>
            `
          )
          .join("");
        resultsEl.innerHTML = candidateHtml + pagefindHtml;
      } catch (error) {
        statusEl.textContent = "検索インデックスの読み込みに失敗しました。";
      }
    }

    inputEl?.addEventListener("input", onInput);
    inputEl?.addEventListener("keydown", (e) => {
      if (!filtered.length) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIndex = Math.min(filtered.length - 1, activeIndex + 1);
        renderSuggestions();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIndex = Math.max(0, activeIndex - 1);
        renderSuggestions();
      } else if (e.key === "Enter" && activeIndex >= 0) {
        e.preventDefault();
        location.href = withBasePath(filtered[activeIndex].path);
      } else if (e.key === "Escape") {
        filtered = [];
        activeIndex = -1;
        renderSuggestions();
      }
    });

    formEl?.addEventListener("submit", () => {
      filtered = [];
      activeIndex = -1;
      renderSuggestions();
    });

    initSuggest();
    runSearch();
  </script>

  <Fragment slot="sidebar">
    <p>検索のヒントや絞り込みUIは後で追加します。</p>
  </Fragment>
</BaseLayout>

<style>
  .searchForm {
    position: relative;
    margin: 8px 0 12px;
    width: 100%;
    max-width: none !important;
  }

  .searchField {
    width: 100%;
    max-width: none;
    height: 66px;
    border-radius: 999px;
    background: #ffffff;
    border: 0;
    display: flex;
    align-items: center;
    padding: 0 24px;
    box-sizing: border-box;
  }

  .searchField:focus-within {
    border-width: 2px;
    border-style: solid;
    border-color: #2f2b36;
  }

  .searchField input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    font-size: 1.35rem;
    font-weight: 500;
    color: #1f1b24;
  }

  .searchField input::placeholder {
    font-size: 1.35rem;
    font-weight: 500;
    color: #4a4650;
  }

  .searchSuggest {
    display: none;
    position: static;
    margin-top: 8px;
    width: 100%;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    padding: 0;
    box-sizing: border-box;
  }

  :global(#searchResults h2) {
    font-size: 2rem !important;
  }

  :global(#searchResults a) {
    font-size: 2rem;
    line-height: 1.35;
  }

  :global(#searchResults p) {
    font-size: 1.85rem;
    line-height: 1.5;
  }
</style>

