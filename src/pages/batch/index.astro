---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../utils/paths";

function toRouteSlug(id: string): string {
  return id.replace(/\.(md|mdx)$/i, "");
}

const title = "バッチ文法";
const items = (await getCollection("batch"))
  .filter((entry) => !entry.id.startsWith("_"))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, "ja"));
---

<BaseLayout title={title}>
  <h1>{title}</h1>
  <p>バッチファイル作成でよく使う文法をまとめています。</p>

  {items.length ? (
    <ul>
      {items.map((item) => (
        <li style="margin-bottom: 10px;">
          <a href={withBase(`/batch/${toRouteSlug(item.id)}/`)}>{item.data.title}</a>
          {" - "}
          <span>{item.data.summary}</span>
        </li>
      ))}
    </ul>
  ) : (
    <p>記事がまだありません。</p>
  )}

  <Fragment slot="sidebar">
    <p>バッチ文法の一覧ページです。</p>
  </Fragment>
</BaseLayout>

